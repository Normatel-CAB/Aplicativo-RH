rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isStatusUsuarioValido(status) {
      return status == 'pendente' || status == 'aprovado' || status == 'rejeitado';
    }

    function isCadastroUsuarioValido() {
      return request.resource.data.keys().hasAll(['email','nome','status','criado_em'])
        && request.resource.data.email is string
        && request.resource.data.nome is string
        && request.resource.data.status is string
        && request.resource.data.criado_em is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() <= 180
        && request.resource.data.nome.size() > 0
        && request.resource.data.nome.size() <= 180
        && isStatusUsuarioValido(request.resource.data.status);
    }

    function isAtualizacaoModeracaoUsuarioValida() {
      return request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status', 'aprovado', 'atualizado_em'])
        && request.resource.data.email == resource.data.email
        && request.resource.data.nome == resource.data.nome
        && request.resource.data.status is string
        && isStatusUsuarioValido(request.resource.data.status)
        && request.resource.data.aprovado is bool
        && (
          (request.resource.data.status == 'aprovado' && request.resource.data.aprovado == true) ||
          (request.resource.data.status == 'rejeitado' && request.resource.data.aprovado == false) ||
          (request.resource.data.status == 'pendente' && request.resource.data.aprovado == false)
        );
    }

    function isEnvioValido() {
      return request.resource.data.keys().hasAll([
          'nome','funcao','projeto','tipo_atestado',
          'data_inicio','data_fim','dias','arquivos','criado_em'
        ])
        && request.resource.data.nome is string
        && request.resource.data.funcao is string
        && request.resource.data.projeto is string
        && request.resource.data.tipo_atestado is string
        && request.resource.data.data_inicio is string
        && request.resource.data.data_fim is string
        && request.resource.data.dias is int
        && request.resource.data.arquivos is list
        && request.resource.data.criado_em is string
        && request.resource.data.nome.size() > 0
        && request.resource.data.nome.size() <= 150
        && request.resource.data.funcao.size() > 0
        && request.resource.data.funcao.size() <= 120
        && request.resource.data.projeto.size() > 0
        && request.resource.data.projeto.size() <= 120
        && request.resource.data.tipo_atestado.size() > 0
        && request.resource.data.tipo_atestado.size() <= 80
        && request.resource.data.dias >= 1
        && request.resource.data.dias <= 365
        && request.resource.data.arquivos.size() >= 1
        && request.resource.data.arquivos.size() <= 10;
    }

    function isAtualizacaoAtendimentoEnvioValida() {
      return request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['atendimento_status', 'atendimento_atualizado_em'])
        && request.resource.data.atendimento_status is string
        && (request.resource.data.atendimento_status == 'feito'
            || request.resource.data.atendimento_status == 'pendente')
        && request.resource.data.atendimento_atualizado_em is string;
    }

    function isSoftDeleteEnvioValido() {
      return request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['excluido', 'excluido_em'])
        && request.resource.data.excluido == true
        && request.resource.data.excluido_em is string;
    }

    function isRestauracaoEnvioValida() {
      return request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['excluido', 'excluido_em'])
        && request.resource.data.excluido == false;
    }

    // Usuários RH:
    // - Leitura autenticada: exige Firebase Auth ativo (estabelecido após login MSAL)
    // - Exceção: verificar existência do email antes do login (endpoint /api/usuarios/existe)
    //   é feito via Cloud Function, não diretamente pelo cliente
    // - Create: registro público com validação de campos obrigatórios
    // - Update: somente campos de moderação (status/aprovado), feito via Cloud Function
    // - Delete: bloqueado diretamente; feito apenas via Cloud Function (que usa Admin SDK)
    match /usuarios_rh/{userDoc} {
      allow read: if request.auth != null;
      allow create: if isCadastroUsuarioValido();
      allow update: if isAtualizacaoModeracaoUsuarioValida();
      allow delete: if false;
    }

    // Atestados enviados:
    // - Leitura autenticada: exige Firebase Auth ativo
    // - Create: formulário público com validação de campos obrigatórios
    // - Update: somente campos permitidos (status de atendimento, soft-delete, restauração)
    //   exige autenticação para proteger dados médicos dos funcionários
    // - Delete permanente: bloqueado; app usa apenas soft-delete (excluido: true)
    match /envios_atestados/{envioDoc} {
      allow read: if request.auth != null;
      allow create: if isEnvioValido();
      allow update: if request.auth != null
                    && (isAtualizacaoAtendimentoEnvioValida()
                        || isSoftDeleteEnvioValido()
                        || isRestauracaoEnvioValida());
      allow delete: if false;
    }

    // Eventos de frontend: escrita pública com rate-limit na Cloud Function
    // Leitura apenas autenticada
    match /eventos_frontend/{eventoDoc} {
      allow read: if request.auth != null;
      allow create: if request.resource.data.keys().hasAll(['acao', 'criado_em'])
                    && request.resource.data.acao is string
                    && request.resource.data.acao.size() > 0
                    && request.resource.data.acao.size() <= 80;
      allow update, delete: if false;
    }

    // Todo o resto: somente usuário autenticado
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
