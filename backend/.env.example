# Exemplo de variáveis de ambiente para o backend RH

# Cole o conteúdo do seu serviceAccount.json (tudo em uma linha, aspas duplas)
FIREBASE_SERVICE_ACCOUNT_JSON={ "type": "service_account", "project_id": "...", ... }

# Nome do bucket do Firebase Storage
FIREBASE_STORAGE_BUCKET=normatel-rh.appspot.com

# Porta do servidor (opcional)
PORT=3001
