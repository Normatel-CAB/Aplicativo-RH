rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Formulário público: upload direto via client SDK
    // Leitura pública necessária enquanto o dashboard admin não usar Firebase Auth
    match /envios/{envioId}/{fileName} {
      allow write: if request.resource.size < 30 * 1024 * 1024
                   && request.resource.contentType == 'application/pdf';
      allow read: if true;
    }

    // Caminho legado: somente leitura, escrita completamente bloqueada
    match /atestados/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Tudo o mais: bloqueado
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
